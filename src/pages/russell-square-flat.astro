---
import Page from '../layouts/Page.astro';
import Gallery from '../components/Gallery.astro';
import { getGallery } from '../lib/galleries';
import { withBase } from '../lib/base';

const images = getGallery('russell-square-flat');
---

<Page
  title="Russell Square Flat"
  bannerImage="/images/1563982101789-PPZBW7VGP9ZEC2M0SFN6/MClayton_1701-A-PERS-ALE_009_D-Lres.jpg"
  bannerAlt="Russell Square flat"
  heading=""
>
  <Fragment slot="banner">
    <p><strong>Modern Art Deco style in this Russell Square flat</strong></p>
    <p>KITCHEN AND BATHROOMS REFURBISHMENT</p>
  </Fragment>

  <Gallery images={images} alt="Russell Square flat interior by Alexandre Interiors" columns={3} />

  <p><a href={withBase('/portfolio')}>← Back to portfolio</a></p>
</Page>
