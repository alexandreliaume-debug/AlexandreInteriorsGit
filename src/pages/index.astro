---
import Base from '../layouts/Base.astro';
---

<Base title="Home" description="If you are looking to create your ideal interior, Alexandre will help you design a space you enjoy returning to and spending time in.">
  <section class="home-hero">
    <div class="container">
      <p class="meta" style="color: rgba(255,255,255,0.85); text-transform: uppercase; letter-spacing: 0.1em;">Alexandre Liaume — Interior Designer</p>
      <h1>Personal and unique designs for living spaces.</h1>
      <p>If you are looking to create your ideal interior, Alexandre will help you design a space you enjoy returning to and spending time in.</p>
      <a class="button" href="/portfolio">View My Work</a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Services</h2>
      <p class="section-intro">Elegant, practical interior designs for homes, offices, shops, restaurants, bars and communities.</p>
      <div class="services-grid">
        <article class="card">
          <h3>Home Interiors</h3>
          <p>Spaces for living — colourful, tasteful and beautiful whilst also being natural, organic and easy to live in.</p>
          <p><a href="/services">Learn more</a></p>
        </article>
        <article class="card">
          <h3>Outdoor Space</h3>
          <p>Versatile outdoor spaces designed to extend how you live and entertain.</p>
          <p><a href="/services">Learn more</a></p>
        </article>
        <article class="card">
          <h3>Commercial</h3>
          <p>Restaurant, hotels, bars — interiors with personality that work for your business.</p>
          <p><a href="/services">Learn more</a></p>
        </article>
      </div>
    </div>
  </section>
</Base>
