---
import Base from './Base.astro';
import { getCollection } from 'astro:content';
import Gallery from '../components/Gallery.astro';
import { getGallery } from '../lib/galleries';
import { withBase } from '../lib/base';

interface Props {
  title: string;
  date: Date;
  description?: string;
  galleryKey?: string;
}

const { title, date, description, galleryKey } = Astro.props;
const gallery = galleryKey ? getGallery(galleryKey) : [];
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title={title} description={description}>
  <div class="main-content">
    <div class="sqs-layout page-width">
      <article class="prose">
        <header class="post-header">
          <p class="meta">{date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
          <h1>{title}</h1>
        </header>
        <slot />
        {gallery.length > 0 && <Gallery images={gallery} alt={title} columns={2} />}
      </article>

      {posts.length > 1 && (
        <section class="related-posts">
          <h2>More from the blog</h2>
          <ul class="post-list">
            {posts.slice(0, 5).map((post) => (
              <li>
                <a href={withBase(`/blog/${post.data.permalink}`)}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </div>
</Base>
