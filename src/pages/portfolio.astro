---
import Page from '../layouts/Page.astro';
import { withBase } from '../lib/base';

const projects = [
  {
    title: 'RUSSEL SQUARE Flat',
    href: '/russell-square-flat',
    image: '/images/1563982132100-YI50VAD2KDFU70UUEAPN/Kitchen1.jpg',
    text: 'Modern Art deco flat..',
  },
  {
    title: 'Hoxton Flat',
    href: '/portfolio/hoxton',
    image: '/images/1563982101789-PPZBW7VGP9ZEC2M0SFN6/MClayton_1701-A-PERS-ALE_009_D-Lres.jpg',
    text: 'Making a stylish and cosy home in London.',
  },
];
---

<Page title="Portfolio" heading="Portfolio">
  <div class="portfolio-grid">
    {projects.map((project) => (
      <article class="portfolio-item">
        <a href={withBase(project.href)}>
          <img src={withBase(project.image)} alt={project.title} loading="lazy" />
        </a>
        <h3><a href={withBase(project.href)}>{project.title}</a></h3>
        <p>{project.text}</p>
        <p><a href={withBase(project.href)}>View photos</a></p>
      </article>
    ))}
  </div>
</Page>
