---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  heading?: string;
}

const { title, description, heading = title } = Astro.props;
---

<Base title={title} description={description}>
  <section class="page-hero">
    <div class="container">
      <h1>{heading}</h1>
    </div>
  </section>
  <section class="page-content">
    <div class="container prose">
      <slot />
    </div>
  </section>
</Base>
