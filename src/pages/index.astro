---
import Base from '../layouts/Base.astro';
import Banner from '../components/Banner.astro';
import { withBase } from '../lib/base';

const services = [
  {
    image: '/images/1500152764492-PBOQJZJV2LD7OYTO1SCR/image-asset.jpeg',
    title: 'HOME INTERIORS',
    text: 'Spaces for living',
  },
  {
    image: '/images/1500152481849-A64SNI83LKK6X83AGQV4/image-asset.jpeg',
    title: 'OUTDOOR SPACE',
    text: 'Versatile outdoor spaces',
  },
  {
    image: '/images/1500152585660-WCFGRADL3DO9LL7LZ39S/Lima01.jpg',
    title: 'COMMERCIAL',
    text: 'Restaurant, hotels, bars,',
  },
];
---

<Base title="Home" description="If you are looking to create your ideal interior, Alexandre will help you design a space you enjoy returning to and spending time in." transparentHeader={true}>
  <section class="index-hero">
    <Banner image="/images/1498472845344-X4LATOYKSK530GXNY1Z3/MClayton_1701-A-PERS-ALE_009_D-Lres.jpg" alt="Alexandre Interiors portfolio" tall={false}>
      <p>Alexandre Liaume - Interior Designer</p>
      <p><strong>Personal and unique designs for living spaces.</strong></p>
      <p><a href={withBase('/portfolio')}>View My Work</a></p>
    </Banner>
  </section>

  <section class="home-intro page-width">
    <h1>If you are looking to create your ideal interior, Alexandre will help you design a space you enjoy returning to and spending time in.</h1>
  </section>

  <section class="service-columns page-width">
    {services.map((service) => (
      <article class="service-column">
        <img src={withBase(service.image)} alt={service.title} loading="lazy" />
        <h3>{service.title}</h3>
        <p>{service.text}</p>
      </article>
    ))}
  </section>
</Base>
